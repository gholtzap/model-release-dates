{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "public",
  "routes": [
    {
      "src": "/api/(.*)",
      "continue": true,
      "transforms": [
        {
          "type": "response.headers",
          "op": "set",
          "target": {
            "key": "access-control-allow-origin"
          },
          "args": "*"
        },
        {
          "type": "response.headers",
          "op": "set",
          "target": {
            "key": "access-control-allow-headers"
          },
          "args": "Content-Type, If-None-Match"
        },
        {
          "type": "response.headers",
          "op": "set",
          "target": {
            "key": "access-control-expose-headers"
          },
          "args": "ETag"
        }
      ]
    },
    {
      "src": "/(.*)",
      "continue": true,
      "headers": {
        "Content-Security-Policy": "default-src 'self'; base-uri 'none'; connect-src 'self'; form-action 'self'; frame-ancestors 'none'; img-src 'self'; object-src 'none'; script-src 'self'; style-src 'self'",
        "Permissions-Policy": "camera=(), microphone=(), geolocation=()",
        "Referrer-Policy": "strict-origin-when-cross-origin",
        "X-Content-Type-Options": "nosniff"
      }
    },
    {
      "src": "/api/identifiers/(?<namespace>[^/]+)/(?<identifier>[^/]+)",
      "dest": "/api/identifier?namespace=$namespace&identifier=$identifier"
    },
    {
      "src": "/api/models/(?<provider>[^/]+)/(?<model>[^/]+)",
      "dest": "/api/model?provider=$provider&model=$model"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/not-found"
    }
  ],
  "functions": {
    "api/models.ts": {
      "includeFiles": "model-release-dates.json"
    },
    "api/model.ts": {
      "includeFiles": "model-release-dates.json"
    },
    "api/identifier.ts": {
      "includeFiles": "model-release-dates.json"
    },
    "api/resolve.ts": {
      "includeFiles": "model-release-dates.json"
    },
    "api/providers.ts": {
      "includeFiles": "model-release-dates.json"
    },
    "api/identifier-namespaces.ts": {
      "includeFiles": "model-release-dates.json"
    },
    "api/lifecycle-statuses.ts": {
      "includeFiles": "model-release-dates.json"
    },
    "api/changes.ts": {
      "includeFiles": "model-release-dates.json"
    }
  }
}
