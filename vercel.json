{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "public",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; base-uri 'none'; connect-src 'self'; form-action 'self'; frame-ancestors 'none'; img-src 'self'; object-src 'none'; script-src 'self'; style-src 'self'"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/identifiers/:namespace/:identifier",
      "destination": "/api/identifier"
    },
    {
      "source": "/api/models/:provider/:model",
      "destination": "/api/model"
    }
  ],
  "functions": {
    "api/models.ts": {
      "includeFiles": "model-release-dates.json"
    },
    "api/model.ts": {
      "includeFiles": "model-release-dates.json"
    },
    "api/identifier.ts": {
      "includeFiles": "model-release-dates.json"
    },
    "api/resolve.ts": {
      "includeFiles": "model-release-dates.json"
    },
    "api/providers.ts": {
      "includeFiles": "model-release-dates.json"
    },
    "api/identifier-namespaces.ts": {
      "includeFiles": "model-release-dates.json"
    },
    "api/lifecycle-statuses.ts": {
      "includeFiles": "model-release-dates.json"
    },
    "api/changes.ts": {
      "includeFiles": "model-release-dates.json"
    }
  }
}
